&#125;

<span class="attr">#[zart_durable("onboarding", timeout = "30m")]</span>
<span class="kw">async fn</span> <span class="fn">onboard</span>(user: <span class="ty">NewUser</span>) -> <span class="ty">Result</span>&lt;<span class="ty">Welcome</span>&gt; &#123;
    <span class="fn">send_welcome</span>(&amp;user.email).<span class="kw">await</span>?;
    <span class="fn">setup_billing</span>(&amp;user).<span class="kw">await</span>?;
    <span class="kw">let</span> _: <span class="ty">Verified</span> = zart::<span class="fn">wait_for_event</span>(<span class="str">"email-confirmed"</span>, <span class="ty">Some</span>(<span class="ty">Duration</span>::<span class="fn">from_secs</span>(<span class="lit">172800</span>))).<span class="kw">await</span>?;
    <span class="fn">provision</span>(&amp;user).<span class="kw">await</span>?;
    <span class="ty">Ok</span>(<span class="ty">Welcome</span>::<span class="fn">for_user</span>(&amp;user))
&#125;</code></pre>
