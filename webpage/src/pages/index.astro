<span class="attr">#[zart_durable("onboarding", timeout = "30m")]</span>
<span class="kw">async fn</span> <span class="fn">onboard</span>(user: <span class="ty">NewUser</span>) -> <span class="ty">Result</span>&lt;<span class="ty">Welcome</span>&gt; &#123;

