  <span class="mac">z_wait_event!</span>(<span class="str">"shipped"</span>, timeout = <span class="str">"24h"</span>).<span class="kw">await</span>?;

  <span class="ty">Ok</span>(<span class="ty">Receipt</span>::<span class="fn">from</span>(charge))
&#125;</code></pre>
