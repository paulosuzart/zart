<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow"><span id="hero-eyebrow-text">Durable Execution for Rust</span></div>
        <h1><span id="hero-word">Agents</span> that <em>survive failure</em></h1>
