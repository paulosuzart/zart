&#125;

<span class="attr">#[zart_step("billing", retry = "exponential(3, 2s)")]</span>
<span class="kw">async fn</span> <span class="fn">setup_billing</span>(user: &amp;<span class="ty">NewUser</span>) -> <span class="ty">Result</span>&lt;<span class="ty">CustomerId</span>&gt; &#123;
