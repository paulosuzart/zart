---
// Zart Landing Page — custom marketing page, not a Starlight doc page
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zart — Workflows that survive failure</title>
  <meta name="description" content="Durable execution for Rust. Write workflows that automatically persist every step to a database, survive process restarts, and never re-run completed work." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32'%3E%3Crect width='32' height='32' rx='6' fill='%234f46e5'/%3E%3Ctext x='16' y='23' font-family='Georgia,serif' font-size='20' font-weight='700' text-anchor='middle' fill='white'%3EZ%3C/text%3E%3C/svg%3E"></link>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --brand:        oklch(63% 0.26 285);
      --brand-low:    oklch(20% 0.09 285);
      --brand-high:   oklch(82% 0.18 285);
      --brand-dim:    oklch(45% 0.18 285);

      --bg:           oklch(9%  0.014 285);
      --bg-card:      oklch(12% 0.022 285);
      --bg-elevated:  oklch(15% 0.028 285);
      --bg-code:      oklch(11% 0.018 285);

      --text:         oklch(94% 0.006 285);
      --text-muted:   oklch(65% 0.04  285);
      --text-faint:   oklch(45% 0.03  285);

      --border:       oklch(22% 0.04  285);
      --border-dim:   oklch(18% 0.03  285);

      --radius-sm:    6px;
      --radius:       10px;
      --radius-lg:    16px;
      --radius-xl:    24px;

      --font-sans:    'Instrument Sans', system-ui, sans-serif;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-mono:    'JetBrains Mono', 'SF Mono', ui-monospace, monospace;

      --max-w:        1200px;
      --section-gap: 7rem;
    }

    html { scroll-behavior: smooth; overflow-x: hidden; }

    body {
      font-family: var(--font-sans);
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    /* ── Layout utils ── */
    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }
    .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

    /* ────────────────────────────────────────
       NAV
    ──────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      /* needed for absolute mobile dropdown */
      border-bottom: 1px solid var(--border-dim);
      background: oklch(9% 0.014 285 / 0.85);
      backdrop-filter: blur(20px) saturate(1.4);
      -webkit-backdrop-filter: blur(20px) saturate(1.4);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      gap: 1rem;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      color: var(--text);
      font-weight: 700;
      font-size: 1.15rem;
      letter-spacing: -0.03em;
    }

    .logo-box {
      width: 30px;
      height: 30px;
      background: var(--brand);
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: Georgia, serif;
      font-size: 17px;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
      box-shadow: 0 2px 12px oklch(63% 0.26 285 / 0.4);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      padding: 0.4rem 0.75rem;
      border-radius: var(--radius-sm);
      transition: color 0.15s, background 0.15s;
    }

    .nav-links a:hover { color: var(--text); background: var(--bg-card); }

    .nav-cta {
      background: var(--brand);
      color: white !important;
      padding: 0.4rem 1rem !important;
      border-radius: var(--radius-sm) !important;
      font-weight: 600 !important;
      box-shadow: 0 2px 10px oklch(63% 0.26 285 / 0.35);
      transition: opacity 0.15s !important;
    }
    .nav-cta:hover { opacity: 0.9; background: transparent !important; }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.4rem;
      border-radius: var(--radius-sm);
    }
    .nav-hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--text-muted);
      border-radius: 2px;
      transition: all 0.2s;
    }

    @media (max-width: 640px) {
      .nav-hamburger { display: flex; }
      .nav-links {
        display: none;
        position: absolute;
        top: 60px;
        left: 0;
        right: 0;
        flex-direction: column;
        background: oklch(12% 0.022 285 / 0.98);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-dim);
        padding: 0.75rem 1rem;
        gap: 0.25rem;
        z-index: 99;
      }
      .nav-links.open { display: flex; }
      .nav-links li { width: 100%; }
      .nav-links a { display: block; padding: 0.6rem 0.75rem; }
      .nav-cta { text-align: center; }
    }

    /* ────────────────────────────────────────
       HERO
    ──────────────────────────────────────── */
    .hero {
      padding: 3rem 0 3rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 600px;
      background: radial-gradient(ellipse at center, oklch(63% 0.26 285 / 0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    /* Prevent grid children from overflowing their column */
    .hero-text, .hero-code { min-width: 0; }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
      .hero-code { order: 2; }
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--brand-low);
      border: 1px solid oklch(63% 0.26 285 / 0.3);
      color: var(--brand-high);
      font-size: 0.8rem;
      font-weight: 600;
      font-family: var(--font-mono);
      padding: 0.35rem 0.8rem;
      border-radius: 100px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    .hero-eyebrow::before {
      content: '';
      width: 6px;
      height: 6px;
      background: var(--brand);
      border-radius: 50%;
      box-shadow: 0 0 6px var(--brand);
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(0.85); }
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 1rem;
      color: var(--text);
    }

    .hero h1 em {
      font-style: italic;
      color: var(--brand-high);
    }

    .hero-sub {
      font-size: 1.1rem;
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 1.25rem;
      max-width: 46ch;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-family: var(--font-sans);
      font-size: 0.95rem;
      font-weight: 600;
      padding: 0.7rem 1.4rem;
      border-radius: var(--radius-sm);
      text-decoration: none;
      transition: all 0.15s ease;
      cursor: pointer;
      border: none;
    }

    .btn-primary {
      background: var(--brand);
      color: white;
      box-shadow: 0 3px 16px oklch(63% 0.26 285 / 0.4);
    }
    .btn-primary:hover {
      background: oklch(68% 0.26 285);
      box-shadow: 0 4px 22px oklch(63% 0.26 285 / 0.55);
      transform: translateY(-1px);
    }

    .btn-ghost {
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
    }
    .btn-ghost:hover {
      color: var(--text);
      border-color: var(--brand);
      background: var(--brand-low);
    }

    /* ── Code window ── */
    .code-window {
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      max-width: 100%;
      box-shadow: 0 24px 64px oklch(0% 0 0 / 0.5), 0 0 0 1px oklch(63% 0.26 285 / 0.08);
    }

    .code-window-bar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--border-dim);
    }

    .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }
    .dot-red   { background: #ff5f57; }
    .dot-amber { background: #febc2e; }
    .dot-green { background: #28c840; }

    .code-window-filename {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-faint);
    }

    .code-window pre {
      padding: 1rem 1.25rem;
      overflow-x: auto;
      overflow-y: auto;
      max-width: 100%;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.65;
      tab-size: 2;
      /* Lock height to the tallest snippet (21 lines) so the window never resizes */
      height: calc(21 * 1.65em + 2rem);
    }

    /* Syntax tokens */
    .kw  { color: oklch(72% 0.2 300); }   /* keywords: use, async, fn, let, Ok  */
    .mac { color: oklch(78% 0.22 55);  }   /* macros: z_step!, z_wait_event! */
    .str { color: oklch(76% 0.18 145); }   /* strings */
    .cmt { color: var(--text-faint); font-style: italic; }
    .ty  { color: oklch(80% 0.16 220); }   /* types: Order, Receipt, Result */
    .fn  { color: oklch(80% 0.2 55);   }   /* function names */
    .attr { color: oklch(72% 0.2 300); }   /* attributes */
    .lit { color: oklch(78% 0.18 55);  }   /* literals */

    /* ────────────────────────────────────────
       PILLARS
    ──────────────────────────────────────── */
    .pillars {
      border-top: 1px solid var(--border-dim);
      border-bottom: 1px solid var(--border-dim);
      background: var(--bg-card);
    }
    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .pillar {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.75rem 2rem;
      border-right: 1px solid var(--border-dim);
      transition: background 0.2s;
    }
    .pillar:last-child { border-right: none; }
    .pillar:hover { background: oklch(14% 0.024 285 / 0.6); }
    .pillar-icon {
      width: 38px;
      height: 38px;
      border-radius: 8px;
      background: var(--brand-low);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
      transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .pillar:hover .pillar-icon { transform: scale(1.12) rotate(-6deg); }
    .pillar-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.3rem;
      letter-spacing: -0.01em;
    }
    .pillar-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.55;
    }
    @media (max-width: 640px) {
      .pillars-grid { grid-template-columns: 1fr; }
      .pillar { border-right: none; border-bottom: 1px solid var(--border-dim); }
      .pillar:last-child { border-bottom: none; }
    }
    @media (min-width: 641px) and (max-width: 900px) {
      .pillar { padding: 1.25rem 1.25rem; }
    }

    /* ── Pill color variants + hover ───────────────────────── */
    .pill {
      transition: all 0.2s ease;
      cursor: default;
    }
    .pill:hover {
      border-color: oklch(63% 0.26 285 / 0.5);
      background: oklch(20% 0.09 285);
      color: var(--brand-high);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px oklch(63% 0.26 285 / 0.15);
    }
    .pill-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--text-faint);
      flex-shrink: 0;
      transition: box-shadow 0.2s;
    }
    .pill-rust { border-color: oklch(70% 0.18 35 / 0.3); }
    .pill-rust .pill-dot { background: oklch(70% 0.18 35); box-shadow: 0 0 4px oklch(70% 0.18 35 / 0.5); }
    .pill-rust:hover { background: oklch(15% 0.06 35); border-color: oklch(70% 0.18 35 / 0.6); color: oklch(88% 0.14 35); box-shadow: 0 4px 14px oklch(70% 0.18 35 / 0.2); }
    .pill-rust:hover .pill-dot { box-shadow: 0 0 8px oklch(70% 0.18 35); }

    .pill-tokio { border-color: oklch(70% 0.2 175 / 0.3); }
    .pill-tokio .pill-dot { background: oklch(70% 0.2 175); box-shadow: 0 0 4px oklch(70% 0.2 175 / 0.5); }
    .pill-tokio:hover { background: oklch(15% 0.06 175); border-color: oklch(70% 0.2 175 / 0.6); color: oklch(88% 0.15 175); box-shadow: 0 4px 14px oklch(70% 0.2 175 / 0.2); }
    .pill-tokio:hover .pill-dot { box-shadow: 0 0 8px oklch(70% 0.2 175); }

    .pill-pg { border-color: oklch(65% 0.18 245 / 0.3); }
    .pill-pg .pill-dot { background: oklch(65% 0.18 245); box-shadow: 0 0 4px oklch(65% 0.18 245 / 0.5); }
    .pill-pg:hover { background: oklch(15% 0.06 245); border-color: oklch(65% 0.18 245 / 0.6); color: oklch(85% 0.14 245); box-shadow: 0 4px 14px oklch(65% 0.18 245 / 0.2); }
    .pill-pg:hover .pill-dot { box-shadow: 0 0 8px oklch(65% 0.18 245); }

    /* ────────────────────────────────────────
       FEATURES
    ──────────────────────────────────────── */
    .features {
      padding: var(--section-gap) 0;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .section-label {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--brand);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--text);
      margin-bottom: 0.75rem;
    }

    .section-sub {
      font-size: 1rem;
      color: var(--text-muted);
      max-width: 56ch;
      margin: 0 auto;
      line-height: 1.7;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    @media (max-width: 900px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .features-grid { grid-template-columns: 1fr; } }

    .feature-card {
      background: var(--bg-card);
      border: 1px solid var(--border-dim);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      transition: border-color 0.2s, transform 0.2s;
    }

    .feature-card:hover {
      border-color: oklch(63% 0.26 285 / 0.4);
      transform: translateY(-2px);
    }

    .feature-icon {
      width: 40px;
      height: 40px;
      background: var(--brand-low);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      font-size: 1.1rem;
    }

    .feature-name {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }

    .feature-desc {
      font-size: 0.875rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ────────────────────────────────────────
       CODE SECTION / TABS
    ──────────────────────────────────────── */
    .code-section {
      padding: var(--section-gap) 0;
      border-top: 1px solid var(--border-dim);
    }

    .tabs-wrapper {
      margin-top: 2.5rem;
    }

    .tab-list {
      display: flex;
      gap: 0.25rem;
      border-bottom: 1px solid var(--border-dim);
      margin-bottom: 0;
      list-style: none;
      overflow-x: auto;
      padding-bottom: 0;
    }

    .tab-btn {
      background: none;
      border: none;
      color: var(--text-faint);
      font-family: var(--font-sans);
      font-size: 0.875rem;
      font-weight: 500;
      padding: 0.65rem 1rem;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color 0.15s, border-color 0.15s;
      white-space: nowrap;
    }

    .tab-btn:hover { color: var(--text-muted); }
    .tab-btn.active {
      color: var(--brand-high);
      border-bottom-color: var(--brand);
    }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .tab-code-window {
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-top: none;
      border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      overflow: hidden;
    }

    /* Sub-tabs for Rust API */
    .sub-tabs {
      display: flex;
      gap: 0.25rem;
      padding: 0.75rem 1rem;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--border-dim);
    }

    @keyframes subtab-glow {
      0%, 100% { box-shadow: 0 0 0 0 oklch(63% 0.26 285 / 0); }
      50%       { box-shadow: 0 0 8px 3px oklch(63% 0.26 285 / 0.45); }
    }

    .sub-tab-btn {
      background: none;
      border: 1px solid transparent;
      color: var(--text-faint);
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 500;
      padding: 0.3rem 0.75rem;
      cursor: pointer;
      border-radius: var(--radius-sm);
      transition: all 0.15s;
      animation: subtab-glow 2s ease-in-out infinite;
    }

    .sub-tab-btn:nth-child(2) {
      animation-delay: 0.6s;
    }

    .sub-tab-btn:hover { color: var(--text-muted); background: var(--bg-card); }
    .sub-tab-btn.active {
      color: var(--brand-high);
      background: var(--brand-low);
      border-color: oklch(63% 0.26 285 / 0.3);
      animation: none;
    }

    .sub-panel { display: none; }
    .sub-panel.active { display: block; }

    .coming-soon-panel {
      padding: 3rem 2rem;
      text-align: center;
    }

    .coming-soon-badge {
      display: inline-block;
      background: oklch(55% 0.2 55 / 0.15);
      border: 1px solid oklch(55% 0.2 55 / 0.4);
      color: oklch(78% 0.18 55);
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 600;
      padding: 0.3rem 0.75rem;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 1rem;
    }

    .coming-soon-panel h3 {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }

    .coming-soon-panel p {
      font-size: 0.875rem;
      color: var(--text-faint);
      max-width: 40ch;
      margin: 0 auto;
    }

    /* ── Rotating word ─────────────────────────────────────── */
    #hero-word {
      display: inline-block;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    #hero-word.exiting {
      opacity: 0;
      transform: translateY(-10px);
    }
    #hero-word.entering {
      opacity: 0;
      transform: translateY(10px);
    }
    /* Stack subtitle paragraphs in the same grid cell so height never shifts */
    .hero-sub-stack { display: grid; }
    .hero-sub-variant {
      grid-area: 1 / 1;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.35s ease;
      pointer-events: none;
    }
    .hero-sub-variant.active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    /* Stack both code windows in the same grid cell so they cross-fade */
    .hero-code-stack {
      display: grid;
      min-width: 0;
      max-width: 100%;
      overflow: hidden;
    }
    .hero-code-variant {
      grid-area: 1 / 1;
      min-width: 0;
      max-width: 100%;
      opacity: 0;
      transition: opacity 0.45s ease;
      pointer-events: none;
    }
    .hero-code-variant.active {
      opacity: 1;
      pointer-events: auto;
    }

    /* ── Scroll reveal ──────────────────────────────────────── */
    @media (prefers-reduced-motion: no-preference) {
      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 { transition-delay: 0.06s; }
      .reveal-delay-2 { transition-delay: 0.13s; }
      .reveal-delay-3 { transition-delay: 0.20s; }
      .reveal-delay-4 { transition-delay: 0.27s; }
      .reveal-delay-5 { transition-delay: 0.34s; }
      .reveal-delay-6 { transition-delay: 0.41s; }
    }

    /* ── Feature card icon animation ────────────────────────── */
    .feature-icon {
      transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1), background 0.25s;
    }
    .feature-card:hover .feature-icon {
      transform: scale(1.15) rotate(-5deg);
      background: oklch(25% 0.11 285);
    }

    /* ── CTA section aurora ─────────────────────────────────── */
    .cta-section {
      position: relative;
      overflow: hidden;
      padding: 5rem 0;
      text-align: center;
      border-top: 1px solid var(--border-dim);
    }
    .cta-section::before {
      content: '';
      position: absolute;
      bottom: -60%;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 350px;
      background: radial-gradient(ellipse, oklch(63% 0.26 285 / 0.11) 0%, transparent 70%);
      pointer-events: none;
      animation: cta-glow 5s ease-in-out infinite;
    }
    @keyframes cta-glow {
      0%, 100% { opacity: 0.6; transform: translateX(-50%) scaleX(1); }
      50% { opacity: 1; transform: translateX(-50%) scaleX(1.25); }
    }

    /* ── Use cases section ────────────────────────────────── */
    .use-cases {
      padding: var(--section-gap) 0;
      border-top: 1px solid var(--border-dim);
    }

    .use-cases-grid {
      display: flex;
      justify-content: space-between;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .use-case-item {
      flex: 1;
      min-width: 200px;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      transition: color 0.2s;
      color: var(--text-muted);
    }

    .use-case-item:hover {
      color: var(--text);
    }

    .use-case-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
      width: 40px;
      text-align: center;
    }

    .use-case-name {
      font-weight: 600;
      font-size: 0.95rem;
      display: block;
    }

    .use-case-detail {
      font-size: 0.85rem;
      opacity: 0.8;
    }

    @media (max-width: 640px) {
      .use-cases-grid { flex-direction: column; gap: 1.5rem; }
    }
      :root { --section-gap: 4rem; }

      .hero { padding: 3rem 0 2.5rem; }

      .hero-sub { font-size: 1rem; }

      .hero-actions { flex-direction: column; align-items: flex-start; }
