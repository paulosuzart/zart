<span class="kw">use</span> radkit::&#123;models::providers::OpenAILlm, agent::LlmFunction&#125;;

<span class="attr">#[zart_durable("ai-brewery-finder", timeout = "10m")]</span>
<span class="kw">async fn</span> <span class="fn">brewery_finder</span>(query: <span class="ty">String</span>) -> <span class="ty">Result</span>&lt;<span class="ty">Report</span>&gt; &#123;

