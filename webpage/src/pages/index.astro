        <span class="ty">Some</span>(<span class="ty">RetryConfig</span>::<span class="fn">exponential</span>(<span class="lit">3</span>, <span class="ty">Duration</span>::<span class="fn">from_secs</span>(<span class="lit">2</span>)))
    &#125;
    <span class="cmt">// No ctx parameter — use zart::context() for introspection</span>
    <span class="kw">async fn</span> <span class="fn">run</span>(&amp;self) -> <span class="ty">Result</span>&lt;(), <span class="ty">StepError</span>&gt; &#123;
        <span class="fn">send_email</span>(&amp;self.email).<span class="kw">await</span>
    &#125;
&#125;

<span class="cmt">/// Compose steps — no ctx, no threading boilerplate</span>
<span class="kw">struct</span> <span class="ty">OnboardingTask</span>;

<span class="attr">#[async_trait]</span>
<span class="kw">impl</span> <span class="ty">DurableExecution</span> <span class="kw">for</span> <span class="ty">OnboardingTask</span> &#123;
    <span class="kw">type</span> <span class="ty">Data</span>   = <span class="ty">OnboardingData</span>;
    <span class="kw">type</span> <span class="ty">Output</span> = ();

    <span class="kw">async fn</span> <span class="fn">run</span>(&amp;<span class="kw">self</span>, data: <span class="ty">OnboardingData</span>) -> <span class="ty">Result</span>&lt;(), <span class="ty">TaskError</span>&gt; &#123;
        zart::<span class="fn">step</span>(<span class="ty">SendEmailStep</span> &#123; email: data.email &#125;).<span class="kw">await</span>?;
        <span class="kw">let</span> _: <span class="ty">VerifyPayload</span> = zart::<span class="fn">wait_for_event</span>(
            <span class="str">"email-verified"</span>,
            <span class="ty">Some</span>(<span class="ty">Duration</span>::<span class="fn">from_secs</span>(<span class="lit">172_800</span>)),
        ).<span class="kw">await</span>?;
        <span class="ty">Ok</span>(())
    &#125;
&#125;</code></pre>
        </div>
      </div>
    </div>
  </div>
</section>

