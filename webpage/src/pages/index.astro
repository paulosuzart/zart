<script>
  // ── Mobile nav toggle ────────────────────────────────────
  const navToggle = document.getElementById('nav-toggle');
  const navLinks  = document.getElementById('nav-links');
  navToggle?.addEventListener('click', () => {
    const open = navLinks.classList.toggle('open');
    navToggle.setAttribute('aria-expanded', String(open));
  });
  // Close nav when a link is clicked
  navLinks?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      navLinks.classList.remove('open');
      navToggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Tab switching ────────────────────────────────────────
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tabId = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + tabId)?.classList.add('active');
    });
  });

  // ── Hero word rotation ───────────────────────────────────
  const VARIANTS = [
    {
      word:    'Agents',
      variant: 'agents',
    },
    {
      word:    'Payments',
      variant: 'payments',
    },
    {
      word:    'Onboardings',
      variant: 'onboarding',
    },
  ];

  let currentIdx = 0;
  const wordEl    = document.getElementById('hero-word');

  function activateVariant(variant) {
    document.querySelectorAll('.hero-sub-variant').forEach(el => {
      el.classList.toggle('active', el.dataset.variant === variant);
    });
    document.querySelectorAll('.hero-code-variant').forEach(el => {
      el.classList.toggle('active', el.dataset.variant === variant);
    });
  }

  function scheduleNext() {
    const dwell = 6500;
    setTimeout(rotateHero, dwell);
  }

  function rotateHero() {
    const next = VARIANTS[(currentIdx + 1) % VARIANTS.length];

    // Step 1 — exit current word
    wordEl.classList.add('exiting');

    setTimeout(() => {
      // Step 2 — swap content while invisible
      wordEl.textContent = next.word;
      wordEl.classList.remove('exiting');
      wordEl.classList.add('entering');
      activateVariant(next.variant);

      // Step 3 — enter new word
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          wordEl.classList.remove('entering');
        });
      });

      currentIdx = (currentIdx + 1) % VARIANTS.length;
      scheduleNext();
    }, 280);
  }

  scheduleNext();
</script>

