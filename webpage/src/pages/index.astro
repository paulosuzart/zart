&#125;

<span class="attr">#[zart_step("receipt")]</span>
<span class="kw">async fn</span> <span class="fn">send_receipt</span>(charge: &amp;<span class="ty">Charge</span>, email: &amp;<span class="ty">str</span>) -> <span class="ty">Result</span>&lt;()&gt; &#123;
