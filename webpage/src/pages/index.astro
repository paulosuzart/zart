---
// Zart Landing Page — custom marketing page, not a Starlight doc page
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zart — Workflows that survive failure</title>
  <meta name="description" content="Durable execution for Rust. Write workflows that automatically persist every step to a database, survive process restarts, and never re-run completed work." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32'%3E%3Crect width='32' height='32' rx='6' fill='%234f46e5'/%3E%3Ctext x='16' y='23' font-family='Georgia,serif' font-size='20' font-weight='700' text-anchor='middle' fill='white'%3EZ%3C/text%3E%3C/svg%3E"></link>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --brand:        oklch(63% 0.26 285);
      --brand-low:    oklch(94% 0.03 285);
      --brand-high:   oklch(82% 0.18 285);
      --brand-dim:    oklch(45% 0.18 285);

      --bg:           oklch(98% 0.003 285);
      --bg-card:      oklch(100% 0 0);
      --bg-elevated:  oklch(94% 0.01 285);
      --bg-code:      oklch(97% 0.015 285);

      --text:         oklch(28% 0.02 285);
      --text-muted:   oklch(55% 0.03 285);
      --text-faint:   oklch(72% 0.02 285);

      --border:       oklch(88% 0.01 285);
      --border-dim:   oklch(93% 0.006 285);

      --radius-sm:    6px;
      --radius:       10px;
      --radius-lg:    16px;
      --radius-xl:    24px;

      --font-sans:    'Instrument Sans', system-ui, sans-serif;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-mono:    'JetBrains Mono', 'SF Mono', ui-monospace, monospace;

      --max-w:        1200px;
      --section-gap: 7rem;
    }

    html { scroll-behavior: smooth; overflow-x: hidden; }

    body {
      font-family: var(--font-sans);
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    /* ── Layout utils ── */
    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }
    .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

    /* ────────────────────────────────────────
       NAV
    ──────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      /* needed for absolute mobile dropdown */
      border-bottom: 1px solid var(--border-dim);
      background: oklch(98% 0.003 285 / 0.85);
      backdrop-filter: blur(20px) saturate(1.4);
      -webkit-backdrop-filter: blur(20px) saturate(1.4);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      gap: 1rem;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      color: var(--text);
      font-weight: 700;
      font-size: 1.15rem;
      letter-spacing: -0.03em;
    }

    .logo-box {
      width: 30px;
      height: 30px;
      background: var(--brand);
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: Georgia, serif;
      font-size: 17px;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
      box-shadow: 0 2px 12px oklch(63% 0.26 285 / 0.4);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      padding: 0.4rem 0.75rem;
      border-radius: var(--radius-sm);
      transition: color 0.15s, background 0.15s;
    }

    .nav-links a:hover { color: var(--text); background: var(--bg-card); }

    .nav-cta {
      background: var(--brand);
      color: white !important;
      padding: 0.4rem 1rem !important;
      border-radius: var(--radius-sm) !important;
      font-weight: 600 !important;
      box-shadow: 0 2px 10px oklch(63% 0.26 285 / 0.35);
      transition: opacity 0.15s !important;
    }
    .nav-cta:hover { opacity: 0.9; background: var(--brand) !important; }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.4rem;
      border-radius: var(--radius-sm);
    }
    .nav-hamburger span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--text-muted);
      border-radius: 2px;
      transition: all 0.2s;
    }

    @media (max-width: 640px) {
      .nav-hamburger { display: flex; }
      .nav-links {
        display: none;
        position: absolute;
        top: 60px;
        left: 0;
        right: 0;
        flex-direction: column;
        background: oklch(100% 0 0 / 0.98);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-dim);
        padding: 0.75rem 1rem;
        gap: 0.25rem;
        z-index: 99;
      }
      .nav-links.open { display: flex; }
      .nav-links li { width: 100%; }
      .nav-links a { display: block; padding: 0.6rem 0.75rem; }
      .nav-cta { text-align: center; }
    }

    /* ────────────────────────────────────────
       HERO
    ──────────────────────────────────────── */
    .hero {
      padding: 3rem 0 3rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 600px;
      background: radial-gradient(ellipse at center, oklch(63% 0.26 285 / 0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    /* Prevent grid children from overflowing their column */
    .hero-text, .hero-code { min-width: 0; }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
      .hero-code { order: 2; }
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--brand-low);
      border: 1px solid oklch(63% 0.26 285 / 0.3);
      color: var(--brand-dim);
      font-size: 0.8rem;
      font-weight: 600;
      font-family: var(--font-mono);
      padding: 0.35rem 0.8rem;
      border-radius: 100px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    .hero-eyebrow::before {
      content: '';
      width: 6px;
      height: 6px;
      background: var(--brand);
      border-radius: 50%;
      box-shadow: 0 0 6px var(--brand);
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(0.85); }
    }

    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 1rem;
      color: var(--text);
    }

    .hero h1 em {
      font-style: italic;
      color: var(--brand);
    }

    .hero-sub {
      font-size: 1.1rem;
      color: var(--text-muted);
      line-height: 1.7;
      margin-bottom: 1.25rem;
      max-width: 46ch;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-family: var(--font-sans);
      font-size: 0.95rem;
      font-weight: 600;
      padding: 0.7rem 1.4rem;
      border-radius: var(--radius-sm);
      text-decoration: none;
      transition: all 0.15s ease;
      cursor: pointer;
      border: none;
    }

    .btn-primary {
      background: var(--brand);
      color: white;
      box-shadow: 0 3px 16px oklch(63% 0.26 285 / 0.4);
    }
    .btn-primary:hover {
      background: oklch(68% 0.26 285);
      box-shadow: 0 4px 22px oklch(63% 0.26 285 / 0.55);
      transform: translateY(-1px);
    }

    .btn-ghost {
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
    }
    .btn-ghost:hover {
      color: var(--text);
      border-color: var(--brand);
      background: var(--brand-low);
    }

    /* ── Code window ── */
    .code-window {
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      max-width: 100%;
      box-shadow: 0 24px 64px oklch(0% 0 0 / 0.12), 0 0 0 1px oklch(63% 0.26 285 / 0.08);
    }

    .code-window-bar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: oklch(92% 0.025 285);
      border-bottom: 1px solid oklch(85% 0.035 285);
    }

    .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }
    .dot-red   { background: #ff5f57; }
    .dot-amber { background: #febc2e; }
    .dot-green { background: #28c840; }

    .code-window-filename {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: oklch(55% 0.05 285);
    }

    .code-window pre {
      padding: 1rem 1.25rem;
      overflow-x: auto;
      overflow-y: auto;
      max-width: 100%;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.65;
      tab-size: 2;
      /* Lock height to the tallest snippet (21 lines) so the window never resizes */
      height: calc(21 * 1.65em + 2rem);
    }

    /* Syntax tokens */
    .kw  { color: oklch(45% 0.18 285); font-weight: 600; }  /* keywords: use, async, fn, let, Ok  */
    .mac { color: oklch(50% 0.18 25);  font-weight: 600; }  /* macros: z_step!, z_wait_event! */
    .str { color: oklch(42% 0.14 145); }                   /* strings */
    .cmt { color: oklch(65% 0.02 285); font-style: italic; } /* comments */
    .ty  { color: oklch(45% 0.14 220); }                   /* types: Order, Receipt, Result */
    .fn  { color: oklch(50% 0.16 55);   }                  /* function names */
    .attr { color: oklch(45% 0.15 300); }                  /* attributes */
    .lit { color: oklch(48% 0.15 55);  }                   /* literals */

    /* ────────────────────────────────────────
       PILLARS
    ──────────────────────────────────────── */
    .pillars {
      border-top: 1px solid var(--border-dim);
      border-bottom: 1px solid var(--border-dim);
      background: var(--bg-card);
    }
    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
    .pillar {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.75rem 2rem;
      border-right: 1px solid var(--border-dim);
      transition: background 0.2s;
    }
    .pillar:last-child { border-right: none; }
    .pillar:hover { background: oklch(95% 0.015 285 / 0.6); }
    .pillar-icon {
      width: 38px;
      height: 38px;
      border-radius: 8px;
      background: var(--brand-low);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
      transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .pillar:hover .pillar-icon { transform: scale(1.12) rotate(-6deg); }
    .pillar-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.3rem;
      letter-spacing: -0.01em;
    }
    .pillar-desc {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.55;
    }
    @media (max-width: 640px) {
      .pillars-grid { grid-template-columns: 1fr; }
      .pillar { border-right: none; border-bottom: 1px solid var(--border-dim); }
      .pillar:last-child { border-bottom: none; }
    }
    @media (min-width: 641px) and (max-width: 900px) {
      .pillar { padding: 1.25rem 1.25rem; }
    }

    /* ── Pill color variants + hover ───────────────────────── */
    .pill {
      transition: all 0.2s ease;
      cursor: default;
    }
    .pill:hover {
      border-color: oklch(63% 0.26 285 / 0.5);
      background: oklch(96% 0.025 285);
      color: var(--brand-dim);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px oklch(63% 0.26 285 / 0.15);
    }
    .pill-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--text-faint);
      flex-shrink: 0;
      transition: box-shadow 0.2s;
    }
    .pill-rust { border-color: oklch(70% 0.18 35 / 0.3); }
    .pill-rust .pill-dot { background: oklch(70% 0.18 35); box-shadow: 0 0 4px oklch(70% 0.18 35 / 0.5); }
    .pill-rust:hover { background: oklch(97% 0.03 35); border-color: oklch(70% 0.18 35 / 0.6); color: oklch(45% 0.14 35); box-shadow: 0 4px 14px oklch(70% 0.18 35 / 0.2); }
    .pill-rust:hover .pill-dot { box-shadow: 0 0 8px oklch(70% 0.18 35); }

    .pill-tokio { border-color: oklch(70% 0.2 175 / 0.3); }
    .pill-tokio .pill-dot { background: oklch(70% 0.2 175); box-shadow: 0 0 4px oklch(70% 0.2 175 / 0.5); }
    .pill-tokio:hover { background: oklch(97% 0.03 175); border-color: oklch(70% 0.2 175 / 0.6); color: oklch(35% 0.12 175); box-shadow: 0 4px 14px oklch(70% 0.2 175 / 0.2); }
    .pill-tokio:hover .pill-dot { box-shadow: 0 0 8px oklch(70% 0.2 175); }

    .pill-pg { border-color: oklch(65% 0.18 245 / 0.3); }
    .pill-pg .pill-dot { background: oklch(65% 0.18 245); box-shadow: 0 0 4px oklch(65% 0.18 245 / 0.5); }
    .pill-pg:hover { background: oklch(96% 0.03 245); border-color: oklch(65% 0.18 245 / 0.6); color: oklch(40% 0.12 245); box-shadow: 0 4px 14px oklch(65% 0.18 245 / 0.2); }
    .pill-pg:hover .pill-dot { box-shadow: 0 0 8px oklch(65% 0.18 245); }

    /* ────────────────────────────────────────
       FEATURES
    ──────────────────────────────────────── */
    .features {
      padding: var(--section-gap) 0;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }

    .section-label {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--brand);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--text);
      margin-bottom: 0.75rem;
      display: inline-block;
      position: relative;
    }

    .features .section-title::after {
      content: '';
      position: absolute;
      bottom: -6px;
      left: 10%;
      right: 10%;
      height: 2px;
      border-radius: 2px;
      background: linear-gradient(90deg, transparent, var(--brand), oklch(63% 0.26 340), var(--brand), transparent);
      background-size: 200% 100%;
      animation: shimmer-title 3s ease-in-out infinite;
    }

    @keyframes shimmer-title {
      0%, 100% { opacity: 0.4; background-position: 0% 50%; }
      50% { opacity: 1; background-position: 100% 50%; }
    }

    .section-sub {
      font-size: 1rem;
      color: var(--text-muted);
      max-width: 56ch;
      margin: 0 auto;
      line-height: 1.7;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    @media (max-width: 900px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .features-grid { grid-template-columns: 1fr; } }

    .feature-card {
      background: var(--bg-card);
      border: 1px solid var(--border-dim);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      transition: border-color 0.2s, transform 0.5s, opacity 0.5s, box-shadow 0.3s;
      opacity: 0.9;
      transform: translateY(30px);
    }

    .feature-card.in-view {
      opacity: 1;
      transform: translateY(0);
    }

    .feature-card:hover {
      border-color: oklch(63% 0.26 285 / 0.6);
      transform: translateY(-4px);
      box-shadow: 0 12px 36px oklch(63% 0.26 285 / 0.18), 0 0 0 1px oklch(63% 0.26 285 / 0.12);
    }

    .feature-card.in-view:hover {
      transform: translateY(-4px);
    }

    /* Expanded animation area for in-view cards */
    .feature-animation {
      width: 100%;
      height: 60px;
      margin-bottom: 0.75rem;
      overflow: hidden;
      transition: height 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .feature-card.in-view .feature-animation {
      height: 100px;
    }

    .feature-card:hover .feature-animation,
    .feature-card.in-view:hover .feature-animation {
      height: 180px;
    }

    .feature-icon {
      width: 40px;
      height: 40px;
      background: var(--brand-low);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      font-size: 1.1rem;
    }

    /* Geometric icon animations */
    .geo-icon { transition: transform 0.3s ease; }
    .feature-card:hover .geo-icon { transform: scale(1.1); }

    /* State Recovery: pulse */
    @keyframes pulse-state {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.15); }
    }
    .geo-state { animation: pulse-state 2.5s ease-in-out infinite; }

    /* Smart Retries: rotate */
    @keyframes rotate-retry {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .geo-retry { animation: rotate-retry 6s linear infinite; transform-origin: 10px 10px; }

    /* Concurrent Workers: spin */
    @keyframes spin-worker {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .geo-worker { animation: spin-worker 8s linear infinite; transform-origin: 10px 10px; }

    /* Timeouts: tick */
    @keyframes tick-time {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(90deg); }
      50% { transform: rotate(180deg); }
      75% { transform: rotate(270deg); }
    }
    .geo-time-hand { animation: tick-time 12s linear infinite; transform-origin: 10px 10px; }

    /* Idempotency: slide bolt */
    @keyframes slide-bolt {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(2px); }
    }
    .geo-lock-bolt { animation: slide-bolt 3s ease-in-out infinite; }

    /* Events: wave expand */
    @keyframes wave-expand {
      0% { transform: scale(1); opacity: 1; }
      100% { transform: scale(1.5); opacity: 0; }
    }
    .geo-wave { animation: wave-expand 2s ease-out infinite; }
    .geo-wave-2 { animation-delay: 0.5s; }

    .feature-animation svg {
      width: 100%;
      height: 100%;
    }

    /* State Recovery animation - isometric with glitch */
    @keyframes db-pulse {
      0%, 100% { fill: var(--brand-low); }
      50% { fill: var(--brand-high); }
    }
    .feature-card.in-view .db-top, .feature-card.in-view .db-bottom { animation: db-pulse 2s ease-in-out infinite; }
    .feature-card.in-view .db-body { animation: db-pulse 2s ease-in-out infinite 0.2s; }

    @keyframes save-flash-anim {
      0%, 25%, 35%, 70%, 100% { opacity: 0; }
      27%, 33% { opacity: 1; }
      72%, 78% { opacity: 1; }
    }
    .feature-card.in-view .save-flash { animation: save-flash-anim 8s ease-in-out infinite; }

    @keyframes step-execute {
      0%, 30% { fill: var(--brand-low); stroke: var(--brand); }
      15% { fill: var(--brand); stroke: var(--brand-dim); }
      35%, 100% { fill: var(--brand-low); stroke: var(--brand); }
    }
    .feature-card.in-view .sr-step1 { animation: step-execute 8s ease-in-out infinite; }
    .feature-card.in-view .sr-step2 { animation: step-execute 8s ease-in-out infinite 2s; }

    @keyframes step3-execute {
      0%, 55% { fill: var(--brand-low); }
      55.1%, 100% { fill: var(--brand-low); }
    }
    .feature-card.in-view .sr-step3 { animation: step3-execute 8s ease-in-out infinite; }

    @keyframes arrow-flow {
      0%, 30% { stroke-dashoffset: 0; opacity: 0; }
      31%, 100% { stroke-dashoffset: -10; opacity: 1; }
    }
    .feature-card.in-view .sr-arrow12 { animation: arrow-flow 8s linear infinite; }
    .feature-card.in-view .sr-arrow23 { animation: arrow-flow 8s linear infinite 2s; }

