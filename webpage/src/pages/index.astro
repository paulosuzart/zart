<span class="attr">#[zart_step("charge")]</span>
<span class="kw">async fn</span> <span class="fn">charge_card</span>(order: &amp;<span class="ty">Order</span>) -> <span class="ty">Result</span>&lt;<span class="ty">Charge</span>&gt; &#123;
