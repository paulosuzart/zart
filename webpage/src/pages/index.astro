<span class="kw">use</span> zart::&#123;<span class="mac">zart_durable</span>, <span class="mac">zart_step</span>&#125;;

<span class="cmt">/// Define each step as a standalone async function</span>
<span class="attr">#[zart_step("send-welcome", retry = "exponential(3, 2s)")]</span>
<span class="kw">async fn</span> <span class="fn">send_welcome</span>(email: &amp;<span class="ty">str</span>) -> <span class="ty">Result</span>&lt;(), <span class="ty">StepError</span>&gt; &#123;
    send_email(email).<span class="kw">await</span>
&#125;

<span class="attr">#[zart_step("setup-billing")]</span>
<span class="kw">async fn</span> <span class="fn">setup_billing</span>(email: &amp;<span class="ty">str</span>) -> <span class="ty">Result</span>&lt;<span class="ty">String</span>, <span class="ty">StepError</span>&gt; &#123;
    <span class="fn">create_stripe_customer</span>(email).<span class="kw">await</span>
&#125;

<span class="cmt">/// Compose steps — no ctx threading, just plain .await</span>
<span class="attr">#[zart_durable("onboarding", timeout = "30m")]</span>
<span class="kw">async fn</span> <span class="fn">onboarding</span>(data: <span class="ty">OnboardingData</span>) -> <span class="ty">Result</span>&lt;(), <span class="ty">TaskError</span>&gt; &#123;
    <span class="fn">send_welcome</span>(&amp;data.email).<span class="kw">await</span>?;
    <span class="kw">let</span> _customer_id = <span class="fn">setup_billing</span>(&amp;data.email).<span class="kw">await</span>?;

    <span class="cmt">// Durable wait — workflow suspends, survives any restart</span>
    <span class="kw">let</span> _: <span class="ty">VerifyPayload</span> =
        zart::<span class="fn">wait_for_event</span>(<span class="str">"email-verified"</span>, <span class="ty">Some</span>(<span class="ty">Duration</span>::<span class="fn">from_secs</span>(<span class="lit">172_800</span>))).<span class="kw">await</span>?;

    <span class="ty">Ok</span>(())
&#125;</code></pre>
        </div>
