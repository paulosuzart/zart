        <span class="cmt">// Step 3 — wait for email verification (up to 48h)</span>
        <span class="kw">let</span> _: <span class="ty">VerifyPayload</span> = ctx.<span class="fn">wait_for_event</span>(
            <span class="str">"email-verified"</span>,
            <span class="ty">Some</span>(<span class="ty">Duration</span>::<span class="fn">from_secs</span>(<span class="lit">172800</span>)),
        ).<span class="kw">await</span>?;

        <span class="ty">Ok</span>(())
    &#125;

    <span class="kw">fn</span> <span class="fn">max_retries</span>(&amp;<span class="kw">self</span>) -> <span class="ty">usize</span> &#123; <span class="lit">3</span> &#125;
    <span class="kw">fn</span> <span class="fn">timeout</span>(&amp;<span class="kw">self</span>) -> <span class="ty">Option</span>&lt;<span class="ty">Duration</span>&gt; &#123;
        <span class="ty">Some</span>(<span class="ty">Duration</span>::<span class="fn">from_secs</span>(<span class="lit">600</span>))
