  &#125;).<span class="kw">await</span>?;

  <span class="cmt">// Fetch brewery data — retries on transient failure</span>
  <span class="kw">let</span> data = <span class="mac">z_step_with_retry!</span>(<span class="str">"fetch"</span>, retries = <span class="lit">3</span>, || <span class="kw">async</span> &#123;
    reqwest::get(&amp;api_url(&amp;city)).<span class="kw">await</span>?.<span class="kw">await</span>.json().<span class="kw">await</span>
  &#125;).<span class="kw">await</span>?;

  <span class="cmt">// LLM summary — only runs if fetch succeeded</span>
  <span class="kw">let</span> summary = <span class="mac">z_step!</span>(<span class="str">"summarize"</span>, || <span class="kw">async</span> &#123;
    LlmFunction::&lt;Summary&gt;::new(llm)
      .run(&amp;format_prompt(&amp;data)).<span class="kw">await</span>
  &#125;).<span class="kw">await</span>?;

  <span class="ty">Ok</span>(<span class="ty">Report</span>::<span class="fn">new</span>(&amp;summary))
&#125;</code></pre>
