&#125;

<span class="attr">#[zart_durable("checkout", timeout = "10m")]</span>
<span class="kw">async fn</span> <span class="fn">checkout</span>(order: <span class="ty">Order</span>) -> <span class="ty">Result</span>&lt;<span class="ty">Receipt</span>&gt; &#123;
